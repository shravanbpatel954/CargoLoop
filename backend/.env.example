# Database
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/cargoloop?retryWrites=true&w=majority

# Third-Party APIs
GEMINI_API_KEY=your_gemini_api_key_here

# Security
JWT_SECRET=your-very-strong-random-secret-minimum-32-characters-long
JWT_EXPIRE_DAYS=30

# CORS (Critical for deployment)
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-deployed-frontend.vercel.app

# Google OAuth (copy from StudyBuddy or Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# URLs for OAuth redirects
FRONTEND_URL=https://your-deployed-frontend.vercel.app
BACKEND_URL=https://your-deployed-backend.onrender.com
